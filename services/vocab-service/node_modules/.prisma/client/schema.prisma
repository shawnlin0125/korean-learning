generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Vocabulary {
  id           String   @id @default(uuid())
  word         String
  romanization String
  meaningZhTw  String
  partOfSpeech String?
  example      String?
  exampleZhTw  String?
  level        String   @default("beginner")
  category     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([level])
  @@index([category])
}
